# =============================================================================
# Pinto Law — Environment Variables
# Copy to .env.local and fill in values
# =============================================================================

# --- Neon Postgres ---
DATABASE_URL=postgresql://neondb_owner:...@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Neon Auth (managed Better Auth) ---
NEON_AUTH_BASE_URL=https://auth.neon.tech/...

# --- Cloudflare R2 (document storage) ---
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pinto-law-docs

# --- AI Inference (demo: OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-...

# --- AI Inference (fallback: Anthropic direct) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
